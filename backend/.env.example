# ===== 서버 =====
JINXUS_HOST=0.0.0.0
JINXUS_PORT=19000
JINXUS_DEBUG=false

# ===== LLM =====
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-4-20250514
CLAUDE_FALLBACK_MODEL=claude-sonnet-4-20250514

# ===== 단기기억 (Redis) =====
REDIS_HOST=localhost
REDIS_PORT=16379
REDIS_PASSWORD=

# ===== 장기기억 (Qdrant) =====
QDRANT_HOST=localhost
QDRANT_PORT=16333

# ===== 임베딩 =====
OPENAI_API_KEY=sk-...

# ===== 메타 저장 =====
SQLITE_PATH=./data/jinxus_meta.db

# ===== 도구 =====
TAVILY_API_KEY=tvly-...
GITHUB_TOKEN=ghp_...

# ===== 자가 강화 =====
AUTO_IMPROVE_THRESHOLD=0.6
REFLECT_EVERY_N_TASKS=10
MAX_PROMPT_VERSIONS=20

# ===== Claude Code =====
CLAUDE_CODE_STORAGE=/tmp/jinxus_sessions
CLAUDE_DANGEROUSLY_SKIP_PERMISSIONS=true

# ===== 텔레그램 =====
TELEGRAM_BOT_TOKEN=
TELEGRAM_AUTHORIZED_USER_ID=0

# ===== MCP (Model Context Protocol) =====
BRAVE_API_KEY=              # Brave Search API (선택, brave-search MCP용)
MCP_ENABLED=true            # MCP 활성화 여부
USE_DYNAMIC_TOOLS=true      # 에이전트 동적 도구 실행 (Claude tool_use)
